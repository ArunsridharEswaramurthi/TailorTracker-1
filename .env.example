# Database connection string for PostgreSQL
# Replace with your actual connection details
DATABASE_URL="postgresql://user:password@host:port/database_name?sslmode=require"

# Secret key for session management
# Replace with a long, random string
SESSION_SECRET="your_very_secret_session_key_here_please_change_me"

# Optional: Host and Port for the Vite development server (usually defaults are fine)
# The main application server will run on port 5000 and proxy Vite requests in development.
# HOST="0.0.0.0"
# PORT=5173
